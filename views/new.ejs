<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Book</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="site-shell">
    <header class="top-nav wrap">
        <a class="brand" href="/">ShelfPilot</a>
        <nav class="nav-links">
            <a href="/books">Books</a>
        </nav>
    </header>

    <main class="wrap stack">
        <section class="page-head">
            <p class="eyebrow">Create</p>
            <h1>Add a New Book</h1>
        </section>

        <form class="book-form" action="/books" method="POST">
            <label for="title">Title</label>
            <input id="title" type="text" name="title" required>

            <label for="author">Author</label>
            <input id="author" type="text" name="author" required>

            <label class="check-row" for="completed">
                <input id="completed" type="checkbox" name="completed">
                Mark as completed
            </label>

            <input class="btn btn-primary" type="submit" value="Add Book">
        </form>
    </main>
</body>
</html>