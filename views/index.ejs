<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book List</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="site-shell">
    <header class="top-nav wrap">
        <a class="brand" href="/">ShelfPilot</a>
        <nav class="nav-links">
            <a href="/books/new">Add Book</a>
        </nav>
    </header>

    <main class="wrap stack">
        <section class="page-head">
            <p class="eyebrow">Bookshelf</p>
            <h1>Pick a Spine, Pull a Book</h1>
            <a class="btn btn-primary" href="/books/new">Add a New Book</a>
        </section>

        <section class="bookshelf-scene">
            <% if (!books || books.length === 0) { %>
                <p class="empty-note">No books on the shelf yet. Add one to start your collection.</p>
            <% } else { %>
                <ul class="shelf-row" aria-label="Bookshelf">
                    <% books.forEach(book=> { %>
                        <li class="shelf-slot">
                            <a class="book-spine" data-pull-link href="/books/<%=book._id; %>" aria-label="Open <%=book.title; %>">
                                <span class="spine-status"><%= book.completed ? 'DONE' : 'READING' %></span>
                                <span class="spine-title"><%=book.title; %></span>
                                <span class="spine-author"><%= book.author %></span>
                            </a>
                            <div class="shelf-actions">
                                <a class="btn btn-ghost btn-mini" href="/books/<%=book._id %>/edit">Edit</a>
                                <form action="/books/<%=book.id %>?_method=DELETE" method="POST">
                                    <input class="btn btn-danger btn-mini" type="submit" value="Delete">
                                </form>
                            </div>
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </section>
    </main>

    <script>
        const pullLinks = document.querySelectorAll('[data-pull-link]');

        pullLinks.forEach((link) => {
            link.addEventListener('click', (event) => {
                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                    return;
                }

                event.preventDefault();
                link.classList.add('pulling');

                setTimeout(() => {
                    window.location.href = link.href;
                }, 220);
            });
        });
    </script>

</body>

</html>