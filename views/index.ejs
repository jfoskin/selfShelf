<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book List</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="site-shell">
    <header class="top-nav wrap">
        <a class="brand" href="/">SelfShelf</a>
        <nav class="nav-links">
            <a href="/books/new">Add Book</a>
        </nav>
    </header>

    <main class="wrap stack">
        <section class="page-head">
            <p class="eyebrow">Bookshelf</p>
            <h1>Pick a Spine, Pull a Book</h1>
            <a class="btn btn-primary" href="/books/new">Add a New Book</a>
        </section>

        <section class="bookshelf-scene">
            <% if (!books || books.length === 0) { %>
                <p class="empty-note">No books on the shelf yet. Add one to start your collection.</p>
            <% } else { %>
                <ul class="shelf-row" aria-label="Bookshelf">
                    <% books.forEach(book=> { %>
                        <li class="shelf-slot">
                            <a
                                class="book-spine <%= book.completed ? 'is-complete' : 'is-reading' %>"
                                data-book-id="<%=book._id; %>"
                                data-book-title="<%=book.title; %>"
                                href="/books/<%=book._id; %>"
                                aria-label="Open actions for <%=book.title; %>">
                                <% if (!book.completed) { %>
                                    <span class="reading-dot" aria-hidden="true"></span>
                                <% } %>
                                <span class="spine-title"><%=book.title; %></span>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            <% } %>
        </section>
    </main>

    <div id="book-action-modal" class="book-modal" hidden>
        <div class="book-modal-backdrop" data-close-modal></div>
        <section class="book-modal-card" role="dialog" aria-modal="true" aria-labelledby="book-modal-title">
            <button type="button" class="modal-close" data-close-modal aria-label="Close popup">x</button>
            <p class="eyebrow">Bookshelf Actions</p>
            <h2 id="book-modal-title" class="modal-book-title"></h2>
            <div class="modal-actions">
                <a id="modal-edit-link" class="btn btn-primary" href="/books">Edit</a>
                <form id="modal-delete-form" action="/books?_method=DELETE" method="POST">
                    <input class="btn btn-danger" type="submit" value="Delete">
                </form>
            </div>
        </section>
    </div>

    <script>
        const bookSpines = document.querySelectorAll('[data-book-id]');
        const modal = document.getElementById('book-action-modal');
        const modalTitle = document.getElementById('book-modal-title');
        const modalEditLink = document.getElementById('modal-edit-link');
        const modalDeleteForm = document.getElementById('modal-delete-form');
        const closeTargets = document.querySelectorAll('[data-close-modal]');

        const closeModal = () => {
            modal.hidden = true;
            document.body.classList.remove('modal-open');
        };

        bookSpines.forEach((spine) => {
            spine.addEventListener('click', (event) => {
                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                    return;
                }

                event.preventDefault();
                const bookId = spine.dataset.bookId;
                const bookTitle = spine.dataset.bookTitle;

                spine.classList.add('pulling');
                setTimeout(() => {
                    spine.classList.remove('pulling');
                }, 220);

                modalTitle.textContent = bookTitle;
                modalEditLink.href = '/books/' + bookId + '/edit';
                modalDeleteForm.action = '/books/' + bookId + '?_method=DELETE';

                modal.hidden = false;
                document.body.classList.add('modal-open');
            });
        });

        closeTargets.forEach((target) => {
            target.addEventListener('click', closeModal);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && !modal.hidden) {
                closeModal();
            }
        });
    </script>

</body>

</html>