<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Library App</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="/styles.css">
	</head>
	<body class="site-shell">
		<header class="top-nav wrap">
			<a class="brand" href="/">ShelfPilot</a>
			<nav class="nav-links">
				<a href="/books">Books</a>
				<a href="/books/<%=book._id%>/edit">Edit</a>
			</nav>
		</header>

		<main class="wrap stack">
			<section class="page-head">
				<p class="eyebrow">Details</p>
				<h1><%=book.title %></h1>
				<p class="detail-meta">Author: <strong><%= book.author%></strong></p>
				<p class="detail-meta">Status: <strong><%= book.completed ? 'Completed' : 'In progress' %></strong></p>
				<div class="cta-row">
					<a class="btn btn-ghost" href="/books">Back to list</a>
					<a class="btn btn-primary" href="/books/<%=book._id%>/edit">Edit book</a>
				</div>
			</section>
		</main>
	</body>
</html>